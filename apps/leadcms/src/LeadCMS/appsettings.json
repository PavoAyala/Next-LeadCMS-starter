{
  "AllowedHosts": "*",
  "MigrateOnStart": true,
  "Plugins": [],
  "Entities": {
    "Include": [],
    "Exclude": []
  },
  "DefaultRoles": [
    "Admin"
  ],
  "DefaultUsers": [
    {
      "UserName": "admin",
      "Email": "admin@admin.com",
      "Password": "adminPass!123",
      "Roles": [
        "Admin"
      ]
    }
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Warning"
      }
    }
  },
  "Postgres": {
    "Server": "ep-fragrant-wind-ai0axia2.c-4.us-east-1.aws.neon.tech",
    "Port": "5432",
    "UserName": "neondb_owner",
    "Password": "npg_PsGk7OnZeBX2",
    "Database": "neondb"
  },
  "Elastic": {
    "Enable": false,
    "Server": "localhost",
    "Port": "9200",
    "UseHttps": false,
    "UserName": "elastic",
    "Password": "elastic",
    "IndexPrefix": "LeadCMS"
  },
  "Email": {
    "Server": "localhost",
    "UserName": "$EMAIL__USERNAME",
    "Password": "$EMAIL__PASSWORD",
    "Port": "1025",
    "UseSsl": "false"
  },
  "TaskRunner": {
    "CronSchedule": "0/30 * * * * ?"
  },
  "Tasks": {
    "DomainVerificationTask": {
      "Enable": false,
      "CronSchedule": "0/30 * * * * ?",
      "RetryCount": "2",
      "RetryInterval": "1",
      "BatchSize": "1",
      "BatchInterval": 1
    },
    "ContactScheduledEmail": {
      "Enable": false,
      "CronSchedule": "0 0/1 * * * ?",
      "RetryCount": "2",
      "RetryInterval": "5"
    },
    "SyncIpDetailsTask": {
      "Enable": false,
      "CronSchedule": "0 0/1 * * * ?",
      "RetryCount": "2",
      "RetryInterval": "5",
      "BatchSize": "50"
    },
    "SyncEsTask": {
      "Enable": true,
      "CronSchedule": "0/30 * * * * ? *",
      "RetryCount": "2",
      "RetryInterval": "5",
      "BatchSize": "500"
    },
    "ContactAccountTask": {
      "Enable": false,
      "CronSchedule": "0/10 * * * * ? *",
      "RetryCount": "2",
      "RetryInterval": "5",
      "BatchSize": "5000"
    },
    "SyncEmailLogTask": {
      "Enable": false,
      "CronSchedule": "0/30 * * * * ? *",
      "RetryCount": "2",
      "RetryInterval": "5",
      "BatchSize": "100"
    },
    "EnrichmentSchedulerTask": {
      "Enable": false,
      "CronSchedule": "0/30 * * * * ? *",
      "RetryCount": "2",
      "RetryInterval": "5",
      "BatchSize": "100"
    },
    "EnrichmentExecutorTask": {
      "Enable": false,
      "CronSchedule": "0/15 * * * * ? *",
      "RetryCount": "2",
      "RetryInterval": "5"
    },
    "MediaMetaUpdateTask": {
      "Enable": true,
      "CronSchedule": "0 0/5 * * * ?",
      "RetryCount": "2",
      "RetryInterval": "5",
      "BatchSize": "100"
    },
    "CampaignSendTask": {
      "Enable": true,
      "CronSchedule": "0 0/1 * * * ?",
      "RetryCount": "2",
      "RetryInterval": "5"
    }
  },
  "Media": {
    "Extensions": [
      ".png",
      ".jpg",
      ".jpeg",
      ".ico",
      ".webp",
      ".svg",
      ".gif",
      ".mp4",
      ".avif",
      ".pdf",
      ".pptx"
    ],
    "MaxSize": [
      {
        "Extension": "default",
        "MaxSize": "500KB"
      },
      {
        "Extension": ".mp4",
        "MaxSize": "10MB"
      },
      {
        "Extension": ".avif",
        "MaxSize": "2MB"
      },
      {
        "Extension": ".pdf",
        "MaxSize": "20MB"
      },
      {
        "Extension": ".pptx",
        "MaxSize": "20MB"
      }
    ]
  },
  "File": {
    "Extensions": [
      ".zip",
      ".xml",
      ".xmlx",
      ".xmlm",
      ".doc",
      ".docx",
      ".txt"
    ],
    "MaxSize": [
      {
        "Extension": "default",
        "MaxSize": "1MB"
      },
      {
        "Extension": ".zip",
        "MaxSize": "3MB"
      }
    ]
  },
  "CacheProfiles": [
    {
      "Type": "ImageResponse",
      "Duration": 1200,
      "VaryByHeader": "User-Agent"
    }
  ],
  "Cors": {
    "AllowedOrigins": [
      "*"
    ]
  },
  "GeolocationApi": {
    "Url": "https://api.ipgeolocation.io/ipgeo",
    "AuthKey": "$GEOLOCATIONAPI__AUTHKEY"
  },
  "ApiSettings": {
    "MaxListSize": 100,
    "MaxRequestBodySize": "5MB",
    "DefaultFromEmail": "no-reply@leadcms.ai",
    "DefaultFromName": "LeadCMS"
  },
  "SupportedLanguages": [
    "en"
  ],
  "EmailVerificationApi": {
    "Url": "https://emailverification.whoisxmlapi.com/api/v2",
    "ApiKey": "$EMAILVERIFICATIONAPI__APIKEY"
  },
  "AccountDetailsApi": {
    "Url": "https://www.klazify.com/api/categorize",
    "ApiKey": "$ACCOUNTDETAILSAPI__APIKEY"
  },
  "Cookies": {
    "Enable": true,
    "Name": "auth_ticket",
    "ExpireTime": "12"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "$AZUREAD__TENANTID",
    "Domain": "$AZUREAD__DOMAIN",
    "ClientId": "$AZUREAD__CLIENTID",
    "Authority": "https://login.microsoftonline.com/$AZUREAD__TENANTID",
    "Scope": "$AZUREAD__SCOPE",
    "ClientSecret": "$AZUREAD__CLIENTSECRET"
  },
  "Jwt": {
    "Secret": "$JWT__SECRET",
    "Issuer": "$JWT__ISSUER",
    "Audience": "$JWT__AUDIENCE"
  },
  "Identity": {
    "LockoutTime": "5",
    "MaxFailedAccessAttempts": "10",
    "RequireDigit": true,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireNonAlphanumeric": true,
    "RequiredLength": 6,
    "RequiredUniqueChars": 1
  },
  "Content": {
    "MinTitleLength": 10,
    "MaxTitleLength": 60,
    "MinDescriptionLength": 20,
    "MaxDescriptionLength": 155,
    "EnableRealtimeSyntaxValidation": true,
    "EnableCodeEditorLineNumbers": true
  }
}