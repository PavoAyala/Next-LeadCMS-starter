# JWT Configuration - CHANGE THESE VALUES!
JWT__SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT__ISSUER=your-application-issuer
JWT__AUDIENCE=your-application-audience

# Default Admin User - CHANGE THESE VALUES!
DEFAULTUSERS__0__USERNAME=admin
DEFAULTUSERS__0__EMAIL=admin@yourdomain.com
DEFAULTUSERS__0__PASSWORD=YourSecurePassword123!
DEFAULTUSERS__0__ROLES__0=Admin

# Email Configuration - CHANGE THESE VALUES!
EMAIL__USERNAME=your-smtp-username
EMAIL__PASSWORD=your-smtp-password
EMAIL__SERVER=localhost
EMAIL__PORT=1025
EMAIL__USESSL=false

# PostgreSQL Configuration (Neon DB) - CHANGE THESE VALUES!
POSTGRES__SERVER=ep-your-endpoint-name.c-4.us-east-1.aws.neon.tech
POSTGRES__PORT=5432
POSTGRES__USERNAME=neondb_owner
POSTGRES__PASSWORD=YourSecureNeonPassword123!
POSTGRES__DATABASE=neondb

# PostgreSQL Configuration - CHANGE THESE VALUES!
#POSTGRES__SERVER=postgres
#POSTGRES__PORT=5432
#POSTGRES__USERNAME=postgres
#POSTGRES__PASSWORD=YourSecurePostgresPassword123!
#POSTGRES__DATABASE=LeadCMS

# CORS Configuration
CORS__ALLOWEDORIGINS__0=http://localhost:8080
CORS__ALLOWEDORIGINS__1=https://yourdomain.com

## Plugins configuration (each plugin must be defined below to be loaded by the core)
# PLUGINS__0=LeadCMS.Core.AIAssistance
# PLUGINS__1=LeadCMS.Plugin.Site

## Site Plugin Configuration
## Root url of the site
# SITEURL=https://yourdomain.com
## A list of recipients who will get notification from contact us form
# CONTACTUS__TO__0="support@yourdomain.com"
## This is an email that will be used as sender for contact us form
# SUPPORTEMAIL=hello@yourdomain.com

# Entities to include (one per line, use indexed keys)
ENTITIES__INCLUDE__0=Contact
ENTITIES__INCLUDE__1=Content
ENTITIES__INCLUDE__2=ContentType
ENTITIES__INCLUDE__3=EmailTemplate
ENTITIES__INCLUDE__4=Link
ENTITIES__INCLUDE__5=Media
ENTITIES__INCLUDE__6=User
ENTITIES__INCLUDE__7=Setting
ENTITIES__INCLUDE__8=Redirect

# Supported languages (one per line, use indexed keys)
SUPPORTEDLANGUAGES__0=en