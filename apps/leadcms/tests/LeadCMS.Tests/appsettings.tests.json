{
  "MigrateOnStart": false,
  "Postgres": {
    "Port": "15432",
    "Database": "LeadCMS-test"
  },
  "Elastic": {
    "Enable": true,
    "Port": "19200",
    "IndexPrefix": "LeadCMS-test"
  },
  "ApiSettings": {
    "MaxListSize": 10,
    "DefaultLanguage": "en"
  },
  "Tasks": {
    "SyncEsTask": {
      "Enable": false,
      "MaxLogRecords": 5
    },
    "DomainVerificationTask": {
      "BatchInterval": 0
    },
    "MediaMetaUpdateTask": {
      "Enable": false
    },
    "CampaignSendTask": {
      "Enable": false
    }
  },
  "Jwt": {
    "Secret": "12345678901234567890123456789012",
    "Issuer": "issuer",
    "Audience": "audience"
  },
  "Identity": {
    "LockoutTime": "0.1",
    "MaxFailedAccessAttempts": "2"
  },
  "Content": {
    "MinTitleLength": 10,
    "MaxTitleLength": 60,
    "MinDescriptionLength": 20,
    "MaxDescriptionLength": 155,
    "EnableRealtimeSyntaxValidation": true,
    "EnableCodeEditorLineNumbers": true
  },
  "SupportedLanguages": [
    "en",
    "fr",
    "de",
    "es",
    "it",
    "ja",
    "zh",
    "ru",
    "pt",
    "nl",
    "ar",
    "sv"
  ]
}
